{
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    },
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5101"
      }
    }
  },
  "Jwt": {
    "Issuer": "clashup-services",
    "EndUserAudience": "clashup-client",
    "InterTierAudience": "clashup-internal",
    "EndUserSigningKey": "",
    "InterTierSigningKey": ""
  },
  "GameServer": {
    "InstanceId": "",
    "PublicEndpoint": "http://localhost:5101",
    "MaxConcurrentMatches": 8,
    "DefaultTickRateHz": 30,
    "ServicesEndpoint": "http://localhost:5001",
    "HeartbeatIntervalSeconds": 2
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Grpc": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
