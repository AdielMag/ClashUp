{
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    },
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5001"
      }
    }
  },
  "Jwt": {
    "Issuer": "clashup-services",
    "EndUserAudience": "clashup-client",
    "InterTierAudience": "clashup-internal",
    "EndUserSigningKey": "",
    "InterTierSigningKey": "",
    "EndUserAccessTokenMinutes": 60,
    "RefreshTokenDays": 30,
    "MatchTokenGraceMinutes": 5
  },
  "Mongo": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "clashup"
  },
  "Matchmaking": {
    "MatchSize": 2,
    "DefaultTickRateHz": 30,
    "DrainIntervalMs": 250
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Routing.EndpointMiddleware": "Information",
        "Grpc": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
